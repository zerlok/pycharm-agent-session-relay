<idea-plugin>
    <id>io.github.zerlok.agentsessionrelay</id>
    <name>Agent Session Relay</name>
    <vendor email="danil.troshnev@gmail.com" url="https://github.com/zerlok">zerlok</vendor>

    <description><![CDATA[
        Review an agent's changes in your IDE and relay batched, line-anchored comments
        back into its running session — instead of retyping feedback into the terminal.<br/>
        <br/>
        <b>How it works</b>
        <ul>
            <li>Hover the editor's <b>left gutter</b> to reveal a <b>+</b> icon — or right-click and
                choose <i>Add review comment</i> — to open an inline comment box (GitHub/GitLab
                style) over the selected lines, or the caret line. Drag the highlighted range's top
                and bottom edges to resize it.</li>
            <li>Press <b>Ctrl/Cmd+Enter</b> to add the comment. It stays in the editor as a
                read-only inline card under its lines — hover the card to reveal its range and its
                <i>Edit</i> / <i>Delete</i> actions — and is listed in the <i>Relay Review</i> tool
                window, grouped by file (double-click to jump to it).</li>
            <li>Press <i>Submit</i> to write a <code>REVIEW.md</code> at the project root using
                Claude Code's <code>@path#L</code> reference syntax, then hand it to your idle agent
                session.</li>
            <li>Use <i>Refresh &amp; review</i> to reload files an agent changed on disk before you
                review them.</li>
        </ul>
        Works in any open file, regardless of its version-control status.<br/>
        <br/>
        <b>Links:</b>
        <ul>
            <li><a href="https://github.com/zerlok/pycharm-agent-session-relay">GitHub</a></li>
            <li><a href="https://github.com/zerlok/pycharm-agent-session-relay/issues">Issues</a></li>
        </ul>
    ]]></description>

    <!-- Works in any IntelliJ-based IDE, including PyCharm. -->
    <depends>com.intellij.modules.platform</depends>
    <!-- The Agent Sessions tool window hosts each session's terminal (task 4.2, design D11/R7). -->
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity
            implementation="io.github.zerlok.agentsessionrelay.ui.RelayHoverInstaller"/>
        <!-- One Relay notification group, reused by ReviewBatchNotifier and AgentSessionNotifier
             (the id is the canonical source those match against). -->
        <notificationGroup id="Agent Session Relay" displayType="BALLOON"/>
        <!-- The normalized agent-event webhook on the IDE built-in web server
             (task 2.2, design D3/D4): POST ${RelayRoute.PREFIX}/sessions/<id>/events/<type>. -->
        <httpRequestHandler
            implementation="io.github.zerlok.agentsessionrelay.gateway.RelayHttpRequestHandler"/>
        <!-- Relay Settings page: start-script configs + per-event sound toggles (task 3.3, design D10).
             App-level because the registry, environment configs and sound toggles are app-level. -->
        <applicationConfigurable id="io.github.zerlok.agentsessionrelay.settings"
                                 parentId="tools"
                                 displayName="Agent Session Relay"
                                 instance="io.github.zerlok.agentsessionrelay.ui.RelayConfigurable"/>
        <!-- id must match ReviewBatchToolWindowFactory.TOOL_WINDOW_ID -->
        <toolWindow id="Relay Review" anchor="bottom" icon="AllIcons.General.Balloon"
                    factoryClass="io.github.zerlok.agentsessionrelay.ui.ReviewBatchToolWindowFactory"/>
        <!-- id must match AgentSessionsToolWindowFactory.TOOL_WINDOW_ID -->
        <toolWindow id="Agent Sessions" anchor="bottom" icon="AllIcons.Actions.Execute"
                    factoryClass="io.github.zerlok.agentsessionrelay.ui.AgentSessionsToolWindowFactory"/>
        <!-- The tool-window side provides the terminal-hosting seam impl (task 4.2); the launch service
             (task 3.2) depends only on the AgentSessionsTerminalHost interface. -->
        <projectService serviceInterface="io.github.zerlok.agentsessionrelay.ui.AgentSessionsTerminalHost"
                        serviceImplementation="io.github.zerlok.agentsessionrelay.ui.AgentSessionsTerminalHostImpl"/>
    </extensions>

    <actions>
        <!-- Right-click "Add review comment" (design D2): opens the inline box over the selection, or
             the caret line when there is no selection — the same range rule as the gutter "+". -->
        <action id="io.github.zerlok.agentsessionrelay.AddReviewComment"
                class="io.github.zerlok.agentsessionrelay.ui.AddReviewCommentAction"
                text="Add Review Comment"
                description="Open an inline review comment box for the selection or caret line">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
